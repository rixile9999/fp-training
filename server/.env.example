# server/.env (이 파일을 .env로 복사해서 채우거나, 셸 환경변수로 주입).
# 키는 절대 커밋하지 않는다(.gitignore에 .env 포함).

# 필수 — Alibaba Cloud DashScope API 키.
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 선택 — region/모델/포트. 기본값은 intl(싱가포르) + qwen-plus.
# 베이징 키면: https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus
PORT=8787
HOST=127.0.0.1

# 선택 — 설정하면 /api/* 호출에 X-Agent-Token 헤더를 요구(localhost 외 노출 시 권장).
# AGENT_API_TOKEN=

# ── 구글 로그인 + 진행상황 영속화 ──────────────────────────────────
# 선택 — 구글 OAuth 웹 클라이언트 ID. 설정하면 "구글로 로그인" 버튼이 켜지고,
# 로그인한 유저의 학습 진행/이벤트가 server/data/ 에 JSON 으로 저장된다.
# 미설정이면 로그인 비활성(게스트 전용, 진행상황은 인메모리).
# 발급: Google Cloud Console → API & Services → Credentials →
#   OAuth client ID (Web application). 승인된 JS 원본에 개발 주소(예:
#   http://localhost:1234)를, 운영이면 실제 도메인을 등록한다.
# GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# 선택 — 세션 쿠키 서명 키. 미설정이면 server/data/.session_secret 에 1회
# 자동 생성된다(서버 재시작 후에도 로그인 유지). 운영에선 명시 권장.
# SESSION_SECRET=

# 선택 — 진행상황 데이터 저장 경로(기본 server/data).
# FPDOJO_DATA_DIR=
