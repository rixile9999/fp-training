# server/.env (이 파일을 .env로 복사해서 채우거나, 셸 환경변수로 주입).
# 키는 절대 커밋하지 않는다(.gitignore에 .env 포함).

# 필수 — Alibaba Cloud DashScope API 키.
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 선택 — region/모델/포트. 기본값은 intl(싱가포르) + qwen-plus.
# 베이징 키면: https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus
PORT=8787
HOST=127.0.0.1

# 선택 — 설정하면 /api/* 호출에 X-Agent-Token 헤더를 요구(localhost 외 노출 시 권장).
# AGENT_API_TOKEN=
